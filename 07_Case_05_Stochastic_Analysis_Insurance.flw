api.databursatil.com/v2/historicos?token=&token.&inicio=&start.&final=&end.&emisora_serie=&emisora.;\n\t%put &=url;\n\t\n\tproc http url=\"&url\" method=\"GET\" out=&emisora_clean.;\n\trun;  \n\t\n\tlibname &emisora_clean. json fileref=&emisora_clean.;\n\n\tproc sql;\n\t\tcreate table &output. as\n\t\tselect\n\t\tinput(p1,yymmdd10.) as date format=date9. label=\"Date\"\n\t\t, input(value,8.) as &emisora_clean. label=\"&emisora. Close price\"\n\t\tfrom &emisora_clean..alldata\n\t\twhere substr(p2,11,1)=\"1\"\n\t\t;\n\tquit;\n\n\tdata &output.;\n\t\tformat rt_&emisora_clean. percentn10.2;\n\t\tlabel rt_&emisora_clean. = \"&emisora Daily return\"; \n\t\tset &output.;\n\t\trt_&emisora_clean. = &emisora_clean./lag(&emisora_clean.) - 1;\n\trun;\n\n\t\n\n%mend;\n\n%let mytoken =4feab5d662f049cdb83d541d2e6a43;\n%put &=token;\n\n%equity_prices(emisora=GMEXICOB,emisora_clean=GMEXICOB,start=2020-11-01,end=2025-12-31,token=&mytoken,output=&_output1);\n%equity_prices(emisora=GFNORTEO,emisora_clean=GFNORTEO,start=2020-11-01,end=2025-12-31,token=&mytoken,output=&_output2);\n%equity_prices(emisora=AMXB,emisora_clean=AMXB,start=2020-11-01,end=2025-12-31,token=&mytoken,output=&_output3);\n%equity_prices(emisora=CEMEXCPO,emisora_clean=CEMEXCPO,start=2020-11-01,end=2025-12-31,token=&mytoken,output=&_output4);\n%equity_prices(emisora=FEMSAUBD,emisora_clean=FEMSAUBD,start=2020-11-01,end=2025-12-31,token=&mytoken,output=&_output5);\n%equity_prices(emisora=WALMEX*,emisora_clean=WALMEX,start=2020-11-01,end=2025-12-31,token=&mytoken,output=&_output6);","logHTML":"","resultsHTML":"","variables":[{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}},{"name":"_output2","value":{"referenceType":"outputPort","portName":"outTables","portIndex":1,"arguments":{}}},{"name":"_output3","value":{"referenceType":"outputPort","portName":"outTables","portIndex":2,"arguments":{}}},{"name":"_output4","value":{"referenceType":"outputPort","portName":"ou