for frequency models","description":"","priority":6,"note":{"id":"","name":"","description":"The criterion to select the best model is the Schwarz Bayesian Criterion.\nThe SQL statement -like \"%Model%\"- is necessary to match the word \"model\" in English or Spanish (it depends on your SAS configuration).","properties":{"UI_PROP_NOTE_DIMENSIONS":"0 0","UI_PROP_IS_EXPANDED":"false","UI_PROP_LOCATION":"1276 162.10749511718748"},"version":1},"properties":{"UI_PROP_LOCATION":"1261 186.96499023437497","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_INPUT_PORT|inTables|1":"|Input table 2|Input tables","UI_PROP_INPUT_PORT|inTables|2":"|Input table 3|Input tables","UI_PROP_INPUT_PORT|inTables|3":"|Input table 4|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"proc sql;\n    create table &_output1 as\n    select \n    \"mylib.cntStr_poisson\" as ds length=30\n    , a.cValue1\n    , b.nValue1\n    from &_input1 a, &_input1 b\n    where a.label1 like \"%Model%\" and b.label1=\"SBC\"\n    union    \n    select \n    \"mylib.cntStr_nb1\" as ds length=30\n    , a.cValue1\n    , b.nValue1\n    from &_input2 a, &_input2 b\n    where a.label1 like \"%Model%\" and b.label1=\"SBC\"\n    union\n    select\n    \"mylib.cntStr_nb2\" as ds length=30\n    , a.cValue1\n    , b.nValue1\n    from &_input3 a, &_input3 b\n    where a.label1 like \"%Model%\" and b.label1=\"SBC\"\n    union\n    select \n    \"mylib.cntStr_cmp\" as ds length=30\n    , a.cValue1\n    , b.nValue1\n    from &_input4 a, &_input4 b\n    where a.label1 like \"%Model%\" and b.label1=\"SBC\"\n    ;\nquit;\n\nproc print data=&_output1;\nrun;","logHTML":"","resultsHTML":"","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIn