:{"type":"numstepper"},"cmHeight":{"type":"numstepper"},"pixelWidth":{"type":"numstepper"},"pixelHeight":{"type":"numstepper"}}},"portMappings":[]},"18785cc0-5b18-11f1-8fed-c7a69f4ee9c5":{"nodeType":"step","id":"18785cc0-5b18-11f1-8fed-c7a69f4ee9c5","version":1,"name":"GARCH(1,1) model","description":"","priority":76,"note":{"id":"","name":"","description":"Modeling a GARCH(1,1) for the log returns on the equity index, and simulating the log returns of the equity index for January 2026.","properties":{"UI_PROP_NOTE_DIMENSIONS":"200 140","UI_PROP_IS_EXPANDED":"false","UI_PROP_LOCATION":"959 995.7162231445311"},"version":1},"properties":{"UI_PROP_LOCATION":"959 1105.716223144531","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"\tdata work.toforecast2;\n        format date date9.;\n        do date = '01JAN2026'd to '31JAN2026'd;\n            log_ret = .;\n            output;\n        end;\n    run;\n\n    /* Estimation and simulation of the GARCH(1,1) model */\n    \n\tproc model data=&_input1(where=(date leq \"31DEC2025\"d));\n\t\tparameters p0 arch0 arch1 garch1;\n\t\tlog_ret = p0;\n\t\th.log_ret = arch0 + arch1 * xlag(resid.log_ret**2,mse.log_ret)+garch1*xlag(h.log_ret,mse.log_ret);\n\t\trestrict \n\t\tarch0 >= 0.00001,\n\t\tarch1 >= 0.00001,\n\t\tgarch1 >= 0.00001;\t\t\t\n\t\tid date;\n\t\t*errormodel log_ret ~ normal(0,h.log_ret);\n\t\tfit log_ret / method=marquardt fiml maxiter=1000 outpredict outactual outs=work.s_garch outest=work.est_garch;\t\n        solve log_ret / data=work.toforecast2 out=&_output1 outpredict random=10 dynamic seed=321 sdata=work.s_garch estdata=work.est_garch;\n    run;\n    \n","contentType":"embedded","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[{"name":"date","version":2,"index":0,"byteLength":8,"charLength":-1,"label":"Date","Aggregate":"","rawLength":8,"formattedLength":9,"type":"Numeric","format":{"name":"DATE9.","length":9},"informat":{"name":"","length":0,"decimals":0}},{"name":"_TYPE_","version":2,"index":1,"byteLength":8,"charLength":8,"label":"Type of Observation","Aggregate":"","rawLength":8,"formattedLength":0,"type":"Char","format":{"name":"","length":0,"decimals":0},"informat":{"name":"","length":0,"decimals":0}},{"name":"_MODE_","version":2,"index":2,"byteLength":8,"charLength":8,"label":"Solution Mode","Aggregate":"","rawLength":8,"formattedLength":0,"type":"Char","format":{"name":"","length":0,"decimals":0},"informat":{"name":"","length":0,"decimals":0}},{"name":"_REP_","version":2,"index":3,"byteLength":8,"charLength":-1,"label":"Replication Number","Aggregate":"","rawLength":8,"formattedLength":0,"type":"Numeric","format":{"name":"","length":0,"decimals":0},"informat":{"name":"","length":0,"decimals":0}},{"name":"_ERRORS_","version":2,"index":4,"byteLength":8,"charLength":-1,"label":"Execution Error Count","Aggregate":"","rawLength":8,"formattedLength":0,"type":"Numeric","format":{"name":"","length":0,"decimals":0},"informat":{"name":"","length":0,"decimals":0}},{"name":"log_ret","version":2,"index":5,"byteLength":8,"charLength":-1,"Aggregate":"","rawLength":8,"formattedLength":0,"type":"Numeric","format":{"name":"","length":0,"decimals":0},"informat":{"name":"","length":0,"decimals":0}}]}}]},"c167a620-5b76-11f1-aa7d-37b1293b1c43":{"nodeType":"step","id":"c167a620-5b76-11f1-aa7d-37b1293b1c43","version":1,"name":"Simulated log-return for January 2026","description":"","priority":77,"note":{"id":"","name":"","