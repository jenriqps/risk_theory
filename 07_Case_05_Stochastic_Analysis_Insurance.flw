dified":false,"inColumn":{"referenceType":"column","version":1,"port":"inTable","portIndex":0,"columnName":"n_siniestro"},"calculatedColumn":null,"modifiedColumn":null,"expressionText":null,"_uuid":"60a2a33c-547a-45a7-b637-01d6322644f3"},{"aggregate":null,"isCalculated":false,"isModified":false,"inColumn":{"referenceType":"column","version":1,"port":"inTable","portIndex":0,"columnName":"m_siniestro"},"calculatedColumn":null,"modifiedColumn":null,"expressionText":null,"_uuid":"8c923da5-27c6-4d00-bb13-9404bc49e134"},{"aggregate":null,"isCalculated":false,"isModified":false,"inColumn":{"referenceType":"column","version":1,"port":"inTable","portIndex":0,"columnName":"f_ocurr_sin"},"calculatedColumn":null,"modifiedColumn":null,"expressionText":null,"_uuid":"c595ccaa-f686-48ec-b7dd-b02eaf88870b"}],"inTable":{"referenceType":"inputPort","portName":"inTable","portIndex":0,"arguments":{"alias":"t1"}},"outTable":{"referenceType":"outputPort","portName":"outTable","portIndex":0,"arguments":{}}},"portMappings":[]},"id-1762884989558-10294":{"nodeType":"outputTable","id":"id-1762884989558-10294","version":1,"name":"MYLIB.RR8AUISINS_2","description":"","priority":28,"note":null,"properties":{"UI_PROP_LOCATION":"808 476.75123291015615","UI_PROP_INPUT_PORT|inTable|0":"|null|","UI_PROP_OUTPUT_PORT|outTable|0":"|null|","usePersistedTableStructure":"false"},"tableReference":{"referenceType":"parameter","parameterId":"id-1762884989558-10294"},"outputTableArguments":{"advancedOptions":[],"arguments":{}}},"id-1762886952619-66126":{"nodeType":"step","id":"id-1762886952619-66126","version":1,"name":"Data processing for frequency model estimation","description":"Compute the number of claims by month.","priority":12,"note":{"id":"","name":"","description":"The output data set contains the number of claims by month on which several counting models are applied.","properties":{"UI_PROP_NOTE_DIMENSIONS":"0 0","UI_PROP_IS_EXPANDED":"false","UI_PROP_LOCATION":"974 274.7149902343749"},"version":1},"properties":{"UI_PROP_LOCATION":"959 299.5724853515624","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"* Sort the input data set;\nproc sort data=&_input1 out=Work.preProcessedData;\nby f_ocurr_sin;\nrun;\n* Based on the f_ocurr_sin variable, count the number of claims per month; \nproc timedata data=Work.preProcessedData seasonality=12 out=WORK._tsoutput;\n\tid f_ocurr_sin interval=month setmissing=missing;\n\tvar m_siniestro / accumulate=n transform=none;\nrun;\n* Rename the counting variable in the output data set; \ndata &_output1(drop=m_siniestro);\n\tformat n_siniestro 3.;\n\tset WORK._tsoutput;\n\tn_siniestro=m_siniestro;\nrun;\n* Delete temporary data sets; \nproc delete data=Work.preProcessedData WORK._tsoutput;\nrun;\n* Print the output data set;\ntitle \"Counting data set\";\nproc print data=&_output1;\nrun;\ntitle;","logHTML":"","resultsHTML":"","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}}],"contentType":"embedded"}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[{"name":"n_siniestro","version":2,"index":0,"byteLength":8,"charLength":-1,"type":"Numeric","format":{"name":"3.","length":3},"Aggregate":"","rawLength":8,"formattedLength":3},{"name":"f_ocurr_sin","version":2,"index":1,"byteLength":8,"charLength":-1,"label":"Fecha de Ocurrencia del Siniestro","type":"Numeric","format":{"name":"MONYY7.","length":7},"Aggregate":"","rawLength":8,"formattedLength":7}]}}]},"id-1763479954662-15778":{"nodeType":"step","id":"id-1763479954662-15778","version":1,"name":"Mean frequency champion model","description":"","priority":10,"note":{"id":"","name":"","description":"The expected number of claims by month is the exponential function applied to the intercept plus the linear combination of parameters and predictive variables.","properties":{"UI_PROP_NOTE_DIMENSIONS":"0 0","UI_PROP_IS_EXPANDED":"false","UI_PROP_LOCATION":"1729 238.6074951171875"},"version":1},"properties":{"UI_PROP_LOCATION":"1714 263.464990234375","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_INPUT_PORT|inTables|1":"|Input table 2|Input tables","UI_PROP_INPUT_PORT|inTables|2":"|Input table 3|Input tables","UI_PROP_INPUT_PORT|inTables|3":"|Input table 4|Input tables","UI_PROP_INPUT_PORT|inTables|4":"|Input table 5|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"\n%macro mean_champion(champ=);\n\n\t%if &champ = mylib.cntStr_poisson %then\n\t%do;\n\t\tproc print data=&_input1;\n\t\trun;\n\t\tproc sql;\n\t\t\tcreate table &_output1 as\n\t\t\tselect exp(intercept) as mean_freq\n\t\t\tfrom &_input1\n\t\t\twhere compress(_type_)=\"PARM\"\n\t\t\t;\n\t\tquit;\n\t%end;\n\t%else %if &champ = mylib.cntStr_nb1  %then\n\t%do;\n\t\tproc print data=&_input2;\n\t\trun;\n\t\tproc sql;\n\t\t\tcreate table &_output1 as\n\t\t\tselect exp(intercept) as mean_freq\n\t\t\tfrom &_input2\n\t\t\twhere compress(_type_)=\"PARM\"\n\t\t\t;\n\t\tquit;\n\t%end;\n\t%else %if &champ = mylib.cntStr_nb2 %then\n\t%do;\n\t\tproc print data=&_input3;\n\t\trun;\n\n\t\tproc sql;\n\t\t\tcreate table &_output1 as\n\t\t\tselect exp(intercept) as mean_freq\n\t\t\tfrom &_input3\n\t\t\twhere compress(_type_)=\"PARM\"\n\t\t\t;\n\t\tquit;\n\t%end;\n\t%else %if &champ = mylib.cntStr_cmp  %then\n\t%do;\n\t\tproc print data=&_input4;\n\t\trun;\n\n\t\tproc sql;\n\t\t\tcreate table &_output1 as\n\t\t\tselect exp(intercept) as mean_freq\n\t\t\tfrom &_input4\n\t\t\twhere compress(_type_)=\"PARM\"\n\t\t\t;\n\t\tquit;\n\t%end;\n\n\t\n%mend;\n\n%let ds_chcnt = %sysfunc(compress(&ds_chcnt, %str( )));\n%put &=ds_chcnt;\n\n%mean_champion(champ=&ds_chcnt);\n\ntitle \"Mean frequency champion model\";\nproc print data=&_output1;\nrun;\ntitle;","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_input2","value":{"referenceType":"inputPort","portName":"inTables","portIndex":1}},{"name":"_input3","value":{"referenceType":"inputPort","portName":"inTables","portIndex":2}},{"name":"_input4","value":{"referenceType":"inputPort","portName":"inTables","portIndex":3}},{"name":"_input5","value":{"referenceType":"inputPort","portName":"inTables","portIndex":4}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}}],"contentType":"embedded"}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[{"name":"mean_freq","version":2,"index":0,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0}]}}]},"id-1763513685906-19992":{"nodeType":"step","id":"id-1763513685906-19992","version":1,"name":"Premium","description":"","priority":16,"note":{"id":"","name":"","description":"The expected value principle is applied with a 40% loading factor.","properties":{"UI_PROP_NOTE_DIMENSIONS":"0 0","UI_PROP_IS_EXPANDED":"false","UI_PROP_LOCATION":"1880 380.39373779296864"},"version":1},"properties":{"UI_PROP_LOCATION":"1865 405.25123291015615","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_INPUT_PORT|inTables|1":"|Input table 2|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"\nproc sql;\n\tcreate table &_output1 as\n\tselect\n\t6000000 as u0 label=\"Initial surplus\"\n\t, mean_freq\n\t, mean_sev\n\t, mean_freq*mean_sev as mean_aggr\n\t, 1.4*calculated mean_aggr as premium \n\tfrom &_input1 a, &_input2 b\n\t;\nquit;\n\ntitle \"Premium\";\nproc print data=&_output1;\nrun;\ntitle;","logHTML":"","resultsHTML":"","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_input2","value":{"referenceType":"inputPort","portName":"inTables","portIndex":1}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}}],"contentType":"embedded"}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[{"name":"u0","version":2,"index":0,"byteLength":8,"charLength":-1,"label":"Initial surplus","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"mean_freq","version":2,"index":1,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"mean_sev","version":2,"index":2,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"mean_aggr","version":2,"index":3,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"premium","version":2,"index":4,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0}]}}]},"id-1764724496699-10020":{"nodeType":"step","id":"id-1764724496699-10020","version":1,"name":"Histogram","description":"","priority":40,"note":null,"properties":{"UI_PROP_LOCATION":"2382 705.4520263671874","UI_PROP_INPUT_PORT|dataSource|0":"|Datos de entrada|","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"stepReference":{"type