description":"We assume a financial portfolio of 6 stocks: GMEXICOB, GFNORTEO, AMXB, CEMEXCPO, FEMSAUBD, WALMEX*.","properties":{"UI_PROP_NOTE_DIMENSIONS":"200 140","UI_PROP_IS_EXPANDED":"false","UI_PROP_LOCATION":"53 995.8587280273437"},"version":1},"properties":{"UI_PROP_LOCATION":"53 1105.716223144531","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Tablas de salida","UI_PROP_OUTPUT_PORT|outTables|1":"|Output table 2|Output tables","UI_PROP_OUTPUT_PORT|outTables|2":"|Output table 3|Output tables","UI_PROP_OUTPUT_PORT|outTables|3":"|Output table 4|Output tables","UI_PROP_OUTPUT_PORT|outTables|4":"|Output table 5|Output tables","UI_PROP_OUTPUT_PORT|outTables|5":"|Output table 6|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"%macro equity_prices(emisora=,emisora_clean=,start=,end=,token=,output=);\n\n\tfilename &emisora_clean. temp;\n\t%let url=https://api.databursatil.com/v2/historicos?token=&token.&inicio=&start.&final=&end.&emisora_serie=&emisora.;\n\t%put &=url;\n\t\n\tproc http url=\"&url\" method=\"GET\" out=&emisora_clean.;\n\trun;  \n\t\n\tlibname &emisora_clean. json fileref=&emisora_clean.;\n\n\tproc sql;\n\t\tcreate table &output. as\n\t\tselect\n\t\tinput(p1,yymmdd10.) as date format=date9. label=\"Date\"\n\t\t, input(value,8.) as &emisora_clean. label=\"&emisora. Close price\"\n\t\tfrom &emisora_clean..alldata\n\t\twhere substr(p2,11,1)=\"1\"\n\t\t;\n\tquit;\n\n\tdata &output.;\n\t\tformat rt_&emisora_clean. percentn10.2;\n\t\tlabel rt_&emisora_clean. = \"&emisora Daily return\"; \n\t\tset &output.;\n\t\trt_&emisora_clean. = &emisora_clean./lag(&emisora_clean.) - 1;\n\trun;\n\n\t\n\n%mend;\n\n%let mytoken =4feab5d662f049cdb83d541d2e6a43;\n%put &=token;\n\n%equity_prices(emisora=GMEXICOB,emisora_clean=GMEXICOB,start=2020-11-01,end=2025-12-31,token=&mytoken,output=&_output1);\n%equit